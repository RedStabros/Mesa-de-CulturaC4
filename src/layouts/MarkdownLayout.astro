---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title || 'Página'} - Mesa de Cultura C4`}>
  <div class="max-w-4xl mx-auto py-8">
    <article class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <header class="bg-gradient-to-r from-gray-50 to-gray-100 px-8 py-10 border-b border-gray-200 text-center relative">
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight mb-4">
              {frontmatter.title}
            </h1>
        </header>
        
        <div class="px-8 py-10 md:px-12 md:py-16 prose prose-lg prose-blue max-w-none prose-img:rounded-xl prose-img:shadow-md prose-headings:text-primary prose-a:text-primary hover:prose-a:text-blue-700">
            <slot />
        </div>
    </article>
  </div>
</Layout>
