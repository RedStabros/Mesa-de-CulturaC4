---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const timelineItems = await getCollection('timeline');

const sortedTimeline = timelineItems.sort((a, b) => {
    if (a.data.title.toLowerCase().includes('antes')) return -1;
    if (b.data.title.toLowerCase().includes('antes')) return 1;
    if (a.data.title.toLowerCase().includes('actualidad')) return 1;
    if (b.data.title.toLowerCase().includes('actualidad')) return -1;
    return a.data.title.localeCompare(b.data.title);
});
---

<Layout title="Nuestra Historia - Línea de Tiempo Comuna 4">
    <section class="relative bg-white dark:bg-gray-900 py-16">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-display font-bold text-primary dark:text-blue-400 mb-4">Nuestra Historia</h1>
            <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
                Un recorrido por los hitos más importantes que han marcado la evolución cultural y social de la Comuna 4 - Aranjuez.
            </p>
        </div>
    </section>

    <section class="py-16 bg-background-light dark:bg-background-dark relative">
        <div class="container mx-auto px-4">
            <div class="relative max-w-5xl mx-auto">
                <!-- Central Vertical Line -->
                <div class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-primary/20 rounded-full"></div>
                
                <div class="space-y-12">
                {sortedTimeline.map((item, index) => {
                    const isEven = index % 2 === 0;
                    const imageSrc = item.data.coverImage ? `/wp-content/uploads/2025/03/${item.data.coverImage}` : "https://lh3.googleusercontent.com/aida-public/AB6AXuBx6NnekSpd35c5NRYotxeucN3hamZkugoDxwDFyerS7samKW5SH4uahB61c8NgMm8aNuI_7dGPpSJxPUtmtUl3sh7S57v70wPWLqm79c7cGrRW3ASu9LDP_cepG8teNlP629N3j8hwll3eC8tynf-KauUBPS4RdNtrbHvcaheFD0-Je3OJnoh8nmBRrwxqqrbuae1VXALTh2blHZziA7EkXrbNk3W0HNgABVq8cQAEMRMNVDLddua1zExrE0U7MPYJA9fKT1tA1Vmp";

                    return (
                        <div class={`relative flex flex-col md:flex-row items-center ${isEven ? 'md:justify-start' : 'md:justify-end'}`}>
                            
                            <!-- Timeline Dot for Medium+ Screens -->
                            <div class="hidden md:flex absolute left-1/2 transform -translate-x-1/2 w-8 h-8 rounded-full bg-white border-4 border-secondary shadow-lg z-10 items-center justify-center">
                                <div class="w-2 h-2 rounded-full bg-primary"></div>
                            </div>

                            <!-- Content Card -->
                            <div class={`w-full md:w-[45%] ${isEven ? 'md:pr-10' : 'md:pl-10'} relative`}>
                                <div class="bg-white dark:bg-surface-dark rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-100 dark:border-gray-700 group">
                                    <div class="flex flex-col sm:flex-row h-full">
                                        <!-- Image Section -->
                                        <div class="w-full sm:w-2/5 md:w-1/3 bg-gray-100 relative overflow-hidden flex-shrink-0 min-h-[160px]">
                                            {item.data.coverImage && (
                                                <img src={imageSrc} alt={item.data.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                                            )}
                                        </div>
                                        
                                        <!-- Text Details -->
                                        <div class="p-6 sm:w-3/5 md:w-2/3 flex flex-col justify-center">
                                            <span class="inline-block px-3 py-1 bg-secondary/10 dark:bg-secondary/20 text-primary dark:text-secondary text-xs font-bold rounded-full mb-3 w-max uppercase tracking-wider">
                                                Hito Histórico
                                            </span>
                                            <h3 class="font-display font-bold text-gray-800 dark:text-white text-2xl mb-3">{item.data.title}</h3>
                                            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed italic border-l-2 border-primary/30 dark:border-secondary/50 pl-3">
                                                [Espacio reservado para el texto histórico de esta década...]
                                            </p>
                                        </div>
                                    </div>
                                    
                                    <!-- Decorative Pointer Arrow -->
                                    <div class={`hidden md:block absolute top-1/2 transform -translate-y-1/2 w-4 h-4 bg-white dark:bg-surface-dark border-t border-r border-gray-100 dark:border-gray-700 ${isEven ? 'right-0 mr-[34px] rotate-45' : 'left-0 ml-[34px] -rotate-[135deg]'} z-0`}></div>
                                </div>
                            </div>
                        </div>
                    );
                })}

                <!-- Actualidad / HOY -->
                <div class="relative flex flex-col items-center justify-center mt-12 mb-8">
                    <div class="w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center shadow-xl z-10 mb-6">
                        <span class="material-icons">star</span>
                    </div>
                    <div class="w-full max-w-lg bg-gradient-to-br from-primary to-[#003855] p-8 rounded-2xl shadow-2xl text-center relative overflow-hidden">
                        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
                        <h3 class="font-display font-bold text-white text-3xl mb-3 relative z-10">Agenda Cultural Vigente</h3>
                        <p class="text-blue-100 relative z-10">
                            Continuamos construyendo tejido social con más de 150 actividades anuales programadas para todos los habitantes de la comuna.
                        </p>
                    </div>
                </div>

                </div>
            </div>
        </div>
    </section>

    <!-- Bottom Statistics Section -->
    <section class="py-16 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row items-center gap-12">
                <div class="w-full md:w-1/2">
                    <h2 class="text-3xl font-display font-bold text-primary dark:text-blue-400 mb-6">Territorio y Memoria</h2>
                    <p class="text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
                        La Línea de Tiempo de la Comuna 4 no es solo una secuencia de fechas; es el reflejo de la resistencia, la creatividad y la unión de nuestros barrios. Desde Moravia hasta Aranjuez, cada hito representa el esfuerzo colectivo de miles de habitantes.
                    </p>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-background-light dark:bg-gray-800 p-4 rounded-lg text-center border border-gray-200 dark:border-gray-700">
                            <span class="text-3xl font-bold text-secondary block mb-1">14</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400 font-semibold uppercase">Barrios</span>
                        </div>
                        <div class="bg-background-light dark:bg-gray-800 p-4 rounded-lg text-center border border-gray-200 dark:border-gray-700">
                            <span class="text-3xl font-bold text-secondary block mb-1">50+</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400 font-semibold uppercase">Organizaciones</span>
                        </div>
                    </div>
                </div>
                <div class="w-full md:w-1/2 relative h-64 md:h-80 bg-gray-200 dark:bg-gray-800 rounded-xl overflow-hidden shadow-inner flex items-center justify-center">
                    <img alt="Mapa de la comuna 4" class="absolute inset-0 w-full h-full object-cover opacity-60 dark:opacity-40 grayscale hover:grayscale-0 transition-all duration-700" src="https://images.unsplash.com/photo-1524661135-423995f22d0b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"/>
                    <div class="z-10 bg-white/90 dark:bg-black/80 backdrop-blur-sm p-6 rounded-lg shadow-lg text-center max-w-xs">
                        <span class="material-icons text-primary dark:text-blue-400 text-4xl mb-2">map</span>
                        <h3 class="font-bold text-gray-800 dark:text-white">Explorar Territorio</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Próximamente mapa interactivo.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
