---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const profilesEntries = await getCollection('profiles');
  return profilesEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} - Mesa de Cultura C4`}>
  <div class="max-w-4xl mx-auto py-8">
    <a href="/base-de-datos-c4" class="inline-flex items-center text-[#3A4676] hover:text-blue-800 font-semibold mb-8 group transition-colors">
      <svg class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Volver a la Base de Datos
    </a>
    
    <article class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <!-- Header Section -->
        <header class="bg-gradient-to-r from-gray-50 to-gray-100 px-8 py-10 border-b border-gray-200 text-center relative">
            {entry.data.coverImage && (
                <div class="mb-6 flex justify-center">
                    <img src={entry.data.coverImage} alt={entry.data.title} class="w-32 h-32 object-contain rounded-full border-4 border-white shadow-lg" />
                </div>
            )}
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight mb-4">
              {entry.data.title}
            </h1>
            {entry.data.date && (
                <div class="flex items-center text-gray-500 font-medium text-sm lg:text-base">
                    <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <time datetime={entry.data.date.toString()}>
                        {new Date(entry.data.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                </div>
            )}
        </header>
        
        <!-- Content Section -->
        <div class="px-8 py-10 md:px-12 md:py-16 prose prose-lg prose-blue max-w-none prose-img:rounded-xl prose-img:shadow-md prose-headings:text-[#3A4676] prose-a:text-[#3A4676] hover:prose-a:text-blue-700">
            {(!entry.body || entry.body.trim().length === 0 || entry.body.toLowerCase().includes('construccion') || entry.body.toLowerCase().includes('construcción')) ? (
               <div class="text-center py-10">
                 <img src="/under-construction.png" alt="En Construcción" class="mx-auto max-w-sm mb-6 drop-shadow-md rounded-2xl" />
                 <h3 class="text-2xl font-bold text-gray-700 mb-2">Página en Construcción</h3>
                 <p class="text-gray-500">Pronto publicaremos más información detallada sobre este perfil cultural.</p>
               </div>
            ) : (
               <Content />
            )}
        </div>
    </article>
  </div>
</Layout>
