---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const profilesEntries = await getCollection('profiles');
  return profilesEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const slugMap = {
  'abracadabra-danza': 'abracadabra',
  'cuarta-estacion-2': 'cuarta-estacion',
  'red-cultural-danc4': 'danc4',
  'jacienta-la-voz': 'jacinta',
  'la-puerta-rosada': 'la-puerta-rosa',
  'unitango-2': 'unitango'
};

const folderName = slugMap[entry.slug] || entry.slug;
const galleryPath = path.join(process.cwd(), 'public/wp-content/gallery', folderName);

let galleryImages = [];
try {
  if (fs.existsSync(galleryPath)) {
    const files = fs.readdirSync(galleryPath);
    galleryImages = files
      .filter(file => /\.(jpg|jpeg|png|webp)$/i.test(file))
      .map(file => `/wp-content/gallery/${folderName}/${file}`);
  }
} catch (e) {
  console.error("No gallery found for: ", folderName);
}
---

<Layout title={`${entry.data.title} - Mesa de Cultura C4`}>
  <div class="max-w-4xl mx-auto py-8">
    <a href="/base-de-datos-c4" class="inline-flex items-center text-[#3A4676] hover:text-blue-800 font-semibold mb-8 group transition-colors">
      <svg class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Volver a la Base de Datos
    </a>
    
    <article class="bg-white/95 dark:bg-gray-800/95 backdrop-blur-sm rounded-2xl shadow-xl overflow-hidden border border-gray-100 dark:border-gray-700">
        <!-- Header Section -->
        <header class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900 px-8 py-10 border-b border-gray-200 dark:border-gray-700 text-center relative">
            {entry.data.coverImage && (
                <div class="mb-6 flex justify-center">
                    <img src={entry.data.coverImage} alt={entry.data.title} class="w-32 h-32 object-contain rounded-full border-4 border-white dark:border-gray-600 shadow-lg" />
                </div>
            )}
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight mb-4">
              {entry.data.title}
            </h1>
            {entry.data.date && (
                <div class="flex items-center text-gray-500 dark:text-gray-400 font-medium text-sm lg:text-base justify-center">
                    <svg class="w-5 h-5 mr-2 text-primary/50 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <time datetime={entry.data.date.toString()}>
                        {new Date(entry.data.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                </div>
            )}
        </header>
        
        <!-- Content Section -->
        <div class="px-8 py-10 md:px-12 md:py-16 prose prose-lg dark:prose-invert prose-blue max-w-none prose-img:rounded-xl prose-img:shadow-md prose-headings:text-primary dark:prose-headings:text-blue-400 prose-a:text-primary hover:prose-a:text-blue-700">
            {(!entry.body || entry.body.trim().length === 0 || entry.body.toLowerCase().includes('construccion') || entry.body.toLowerCase().includes('construcción')) ? (
               <div class="text-center py-10">
                 <h3 class="text-2xl font-bold text-gray-700 dark:text-gray-300 mb-2">Página en Construcción</h3>
                 <p class="text-gray-500 dark:text-gray-400">Pronto publicaremos más información detallada sobre este perfil cultural.</p>
               </div>
            ) : (
               <Content />
            )}
        </div>

        {/* Gallery Section */}
        {galleryImages.length > 0 && (
            <div class="px-8 pb-10 md:px-12 md:pb-16 mt-4 border-t border-gray-100 dark:border-gray-700 pt-12">
                <h3 class="text-3xl font-display font-bold text-gray-800 dark:text-white mb-2 text-center drop-shadow-sm">Nuestra Galería</h3>
                <p class="text-center text-gray-500 dark:text-gray-400 mb-8 italic">Momentos y recuerdos registrados</p>
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                    {galleryImages.map((imgSrc, index) => (
                        <div class="aspect-square w-full rounded-xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 relative group bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                            <a data-fslightbox={`gallery-${entry.slug}`} href={imgSrc} class="w-full h-full block">
                                <img 
                                    src={imgSrc} 
                                    alt={`Galería ${entry.data.title} ${index + 1}`} 
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                    loading="lazy"
                                />
                                <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/20 dark:group-hover:bg-black/40 transition-colors duration-300 pointer-events-none"></div>
                            </a>
                        </div>
                    ))}
                </div>
            </div>
        )}
    </article>
  </div>
</Layout>
