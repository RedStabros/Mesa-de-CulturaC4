---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProfiles = await getCollection('profiles');
---

<Layout title="Inicio - Mesa de Cultura C4">
  <!-- Hero Section -->
  <section class="relative w-full overflow-hidden mt-6 mb-16 rounded-3xl shadow-2xl bg-white dark:bg-gray-800">
    <!-- Contenedor con aspecto asimétrico o de dos columnas -->
    <div class="flex flex-col lg:flex-row">
      <!-- Image side -->
      <div class="w-full lg:w-3/5 h-[400px] lg:h-[600px] relative">
        <div class="absolute inset-0 bg-primary/20 dark:bg-black/40 z-10 mix-blend-overlay"></div>
        <img 
          src="/wp-content/uploads/2025/03/1.4.png" 
          alt="Agenda Cultural Comuna 4" 
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Text side -->
      <div class="w-full lg:w-2/5 flex flex-col justify-center p-10 lg:p-16 relative z-20">
        <span class="inline-block px-4 py-1.5 bg-secondary/20 dark:bg-secondary/30 text-primary dark:text-secondary font-bold rounded-full text-sm uppercase tracking-widest mb-6 w-max border border-secondary/30">
          Bienvenidos
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-extrabold text-gray-900 dark:text-white tracking-tight mb-6 leading-tight">
          Mesa de Cultura <span class="text-primary dark:text-blue-400">C4</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 font-body mb-10 leading-relaxed">
          Agenda Cultural Comuna 4 Aranjuez. Construyendo tejido social y memoria ciudadana a través del arte y la participación comunitaria.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/linea-de-tiempo" class="inline-flex justify-center items-center px-8 py-3.5 border-2 border-primary bg-primary text-white font-bold rounded-xl hover:bg-transparent hover:text-primary dark:hover:text-white dark:border-blue-500 dark:bg-blue-600 dark:hover:bg-transparent transition-all duration-300 shadow-lg hover:shadow-xl">
            Nuestra Historia
          </a>
          <a href="/base-de-datos-c4" class="inline-flex justify-center items-center px-8 py-3.5 border-2 border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-bold rounded-xl hover:border-secondary hover:text-secondary dark:hover:border-secondary dark:hover:text-secondary transition-all duration-300">
            Directorio C4
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
